# Backend used when VITE_USE_LOCAL_API=true
VITE_API_URL_LOCAL=http://localhost:3000
# Backend used when VITE_USE_LOCAL_API=false (deployed Render backend)
VITE_API_URL_DEPLOYED=https://manavidya-backend-staging.onrender.com
# Toggle which of the two above the dev server talks to. Restart `npm run dev` after changing.
VITE_USE_LOCAL_API=false
